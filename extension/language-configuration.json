{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["{", "}"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["{", "}"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(if|fun|class|loop|begin)\\b",
      "end": "^\\s*end\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if|elif|else|fun|class|loop|begin|rescue|ensure)\\b",
    "decreaseIndentPattern": "^\\s*(end|elif|else|rescue|ensure)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(if|elif|else|fun|class|loop|begin|rescue|ensure)\\b.*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*end\\b.*$",
      "action": { "indent": "outdent" }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
