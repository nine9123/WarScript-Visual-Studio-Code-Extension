{
  "scopeName": "source.warscript",
  "name": "WarScript",
  "fileTypes": ["ws"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string-interpolation" },
    { "include": "#numeric" },
    { "include": "#const-definition" },
    { "include": "#enum-definition" },
    { "include": "#function-definition" },
    { "include": "#class-definition" },
    { "include": "#function-call" },
    { "include": "#class-method-call" },
    { "include": "#keyword-control" },
    { "include": "#keyword-operator" },
    { "include": "#constant-boolean" },
    { "include": "#constant-null" },
    { "include": "#variable-this" },
    { "include": "#compound-assignment-operator" },
    { "include": "#operator" },
    { "include": "#range-operator" },
    { "include": "#class-access-operator" },
    { "include": "#colon-separator" },
    { "include": "#punctuation-brackets" },
    { "include": "#punctuation-comma" },
    { "include": "#variable" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.warscript"
    },

    "string-interpolation": {
      "name": "string.quoted.double.warscript",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.warscript" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.warscript" }
      },
      "patterns": [
        {
          "name": "meta.interpolation.warscript",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.warscript" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.warscript" }
          },
          "patterns": [
            { "include": "source.warscript" }
          ]
        },
        {
          "name": "string.quoted.double.warscript",
          "match": "[^\"{}]+"
        }
      ]
    },

    "numeric": {
      "match": "(?<![a-zA-Z_])(-?\\b[0-9][0-9_]*(\\.[0-9_]+)?\\b)",
      "name": "constant.numeric.warscript"
    },

    "const-definition": {
      "match": "\\b(const)\\s+([A-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.warscript" },
        "2": { "name": "variable.other.constant.warscript" }
      }
    },

    "enum-definition": {
      "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.warscript" },
        "2": { "name": "entity.name.type.enum.warscript" }
      }
    },

    "function-definition": {
      "match": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.warscript" },
        "2": { "name": "entity.name.function.warscript" }
      }
    },

    "class-definition": {
      "match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s*(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*))?",
      "captures": {
        "1": { "name": "keyword.control.warscript" },
        "2": { "name": "entity.name.class.warscript" },
        "3": { "name": "punctuation.separator.inheritance.warscript" },
        "4": { "name": "entity.other.inherited-class.warscript" }
      }
    },

    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\[)",
      "captures": {
        "1": { "name": "entity.name.function.call.warscript" }
      }
    },

    "class-method-call": {
      "match": "::\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\[)",
      "captures": {
        "1": { "name": "entity.name.function.call.warscript" }
      }
    },

    "keyword-control": {
      "match": "\\b(if|elif|else|end|print|fun|class|return|loop|in|by|break|next|assert|raise|begin|rescue|ensure|import|yield|const|enum)\\b",
      "name": "keyword.control.warscript"
    },

    "keyword-operator": {
      "match": "\\b(and|or|not|new|as|is)\\b",
      "name": "keyword.operator.warscript"
    },

    "constant-boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.warscript"
    },

    "constant-null": {
      "match": "\\bnull\\b",
      "name": "constant.language.null.warscript"
    },

    "variable-this": {
      "match": "\\bthis\\b",
      "name": "variable.language.this.warscript"
    },

    "compound-assignment-operator": {
      "match": "\\+=|-=|\\*=|/=",
      "name": "keyword.operator.assignment.compound.warscript"
    },

    "operator": {
      "match": "\\+|-|\\*|/|%|>=|<=|==|!=|!|<<|>|<|=|\\(|\\)",
      "name": "keyword.operator.warscript"
    },

    "range-operator": {
      "match": "\\.\\.",
      "name": "keyword.operator.range.warscript"
    },

    "class-access-operator": {
      "match": "::",
      "name": "keyword.operator.access.warscript"
    },

    "colon-separator": {
      "match": "(?<!:):(?!:)",
      "name": "punctuation.separator.warscript"
    },

    "punctuation-brackets": {
      "match": "[\\[\\]{}()]",
      "name": "punctuation.bracket.warscript"
    },

    "punctuation-comma": {
      "match": ",",
      "name": "punctuation.separator.comma.warscript"
    },

    "variable": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.warscript"
    }
  }
}
